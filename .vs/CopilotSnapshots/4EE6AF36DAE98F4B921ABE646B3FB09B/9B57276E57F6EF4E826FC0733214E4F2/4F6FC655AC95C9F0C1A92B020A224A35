        // جديد: تجميع منطق البحث والفلترة حسب الحالة في مكان واحد
        private void ApplyFilters()
        {
            if (dgvHouses == null) return;

            string keyword = txtSearch.Text.Contains("Search...") ? "" : txtSearch.Text.Trim().ToLower();
            string statusFilter = cmbStatusFilter.SelectedItem?.ToString() ?? "All";

            var filtered = houseList.Where(h =>
                (string.IsNullOrEmpty(keyword) ||
                 h.Name.ToLower().Contains(keyword) ||
                 h.Address.ToLower().Contains(keyword)) &&
                (statusFilter == "All" || h.Status == statusFilter)
            ).ToList();

            dgvHouses.Rows.Clear();
            foreach (var house in filtered)
            {
                dgvHouses.Rows.Add(house.ID, house.Name, house.Address, house.Status);
            }
        }

        // جديد: تصدير قائمة المنازل الحالية إلى ملف CSV
        private void ExportToCsv()
        {
            try
            {
                using (SaveFileDialog sfd = new SaveFileDialog())
                {
                    sfd.Filter = "CSV Files (*.csv)|*.csv";
                    sfd.FileName = "houses_export.csv";
                    if (sfd.ShowDialog() == DialogResult.OK)
                    {
                        var lines = new List<string> { "ID,Name,Address,Status" };
                        lines.AddRange(houseList.Select(h => $"{h.ID},\"{h.Name}\",\"{h.Address}\",{h.Status}"));
                        File.WriteAllLines(sfd.FileName, lines);
                        MessageBox.Show("تم تصدير البيانات بنجاح.", "تم التصدير", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
            }
            catch
            {
                MessageBox.Show("حدث خطأ أثناء تصدير الملف.", "خطأ", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void HandleDeleteHouse()
        {
            if (dgvHouses.SelectedRows.Count > 0)
            {
                string houseId = dgvHouses.SelectedRows[0].Cells["ID"].Value.ToString();
                string houseName = dgvHouses.SelectedRows[0].Cells["Name"].Value.ToString();

                DialogResult result = MessageBox.Show($"هل أنت متأكد من حذف ({houseName})؟", "تأكيد الحذف", MessageBoxButtons.YesNo, MessageBoxIcon.Warning);

                if (result == DialogResult.Yes)
                {
                    var target = houseList.FirstOrDefault(h => h.ID == houseId);
                    if (target != null)
                    {
                        houseList.Remove(target);

                        for (int i = 0; i < houseList.Count; i++)
                        {
                            houseList[i].ID = (i + 1).ToString();
                        }
                    }

                    SaveData(); // جديد: حفظ بعد الحذف

                    txtSearch.Text = " 🔍 Search...";
                    txtSearch.ForeColor = Color.DarkGray;
                    txtSearch.Font = new Font("Segoe UI", 11, FontStyle.Italic);

                    ShowHousesGrid();
                    btnDeleteHouse.Visible = false;
                    btnEditHouse.Visible = false;
                }
            }
        }

        // جديد: منطق فتح نافذة التعديل مع تعبئة بيانات المنزل المختار
        private void HandleEditHouse()
        {
            if (dgvHouses.SelectedRows.Count == 0) return;

            string houseId = dgvHouses.SelectedRows[0].Cells["ID"].Value.ToString();
            houseBeingEdited = houseList.FirstOrDefault(h => h.ID == houseId);
            if (houseBeingEdited == null) return;

            lblDialogTitle.Text = "Edit House Details";
            btnSave.Text = "UPDATE";

            txtNewName.Text = houseBeingEdited.Name;
            txtNewName.ForeColor = Color.White;
            txtNewAddress.Text = houseBeingEdited.Address;
            txtNewAddress.ForeColor = Color.White;
            cmbNewStatus.SelectedItem = houseBeingEdited.Status;

            pnlAddHouseDialog.Visible = true;
            pnlAddHouseDialog.BringToFront();
        }

