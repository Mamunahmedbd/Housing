        // ===================== ميزة جديدة: الحفظ والتحميل من ملف JSON =====================
        private void LoadData()
        {
            try
            {
                if (File.Exists(dataFilePath))
                {
                    string json = File.ReadAllText(dataFilePath);
                    var serializer = new DataContractJsonSerializer(typeof(List<House>));
                    using (var ms = new MemoryStream(Encoding.UTF8.GetBytes(json)))
                    {
                        var loaded = (List<House>)serializer.ReadObject(ms);
                        if (loaded != null && loaded.Count > 0)
                        {
                            houseList = loaded;
                            return;
                        }
                    }
                }
            }
            catch { /* في حال تلف الملف نعتمد البيانات الافتراضية */ }

            InitializeDefaultData();
        }

        private void SaveData()
        {
            try
            {
                var serializer = new DataContractJsonSerializer(typeof(List<House>));
                using (var ms = new MemoryStream())
                {
                    serializer.WriteObject(ms, houseList);
                    string json = Encoding.UTF8.GetString(ms.ToArray());
                    File.WriteAllText(dataFilePath, json);
                }
            }
            catch
            {
                MessageBox.Show("تعذر حفظ البيانات على القرص.", "خطأ في الحفظ", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
        }
