        private TextBox CreateDialogTextBox(string placeholder, int x, int y, int width = 240)
{
    TextBox txt = new TextBox
    {
        Text = placeholder,
        BackColor = inputBgColor,
        ForeColor = Color.DarkGray,
        Font = new Font("Segoe UI", 11, FontStyle.Regular),
        Location = new Point(x, y),
        Size = new Size(width, 35),
        BorderStyle = BorderStyle.FixedSingle
    };

    txt.Enter += (s, e) => {
        if (txt.Text == placeholder)
        {
            txt.Text = "";
            txt.ForeColor = Color.White;
        }
    };

    txt.Leave += (s, e) => {
        if (string.IsNullOrWhiteSpace(txt.Text))
        {
            txt.Text = placeholder;
            txt.ForeColor = Color.DarkGray;
        }
    };

    return txt;
}

private bool ValidateHouseInput()
{
    string name = txtNewName.Text == "House Name" ? "" : txtNewName.Text;
    string address = txtNewAddress.Text == "Address" ? "" : txtNewAddress.Text;

    if (string.IsNullOrWhiteSpace(name))
    {
        MessageBox.Show("Please enter a house name.", "Validation Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
        txtNewName.Focus();
        return false;
    }

    if (string.IsNullOrWhiteSpace(address))
    {
        MessageBox.Show("Please enter an address.", "Validation Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
        txtNewAddress.Focus();
        return false;
    }

    if (!decimal.TryParse(txtNewPrice.Text, out _))
    {
        MessageBox.Show("Please enter a valid price.", "Validation Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
        txtNewPrice.Focus();
        return false;
    }

    return true;
}

