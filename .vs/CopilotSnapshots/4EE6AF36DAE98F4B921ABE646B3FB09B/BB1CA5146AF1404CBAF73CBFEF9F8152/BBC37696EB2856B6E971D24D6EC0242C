private void HandleEditHouse()
{
    if (dgvHouses.SelectedRows.Count > 0)
    {
        string houseId = dgvHouses.SelectedRows[0].Cells["ID"].Value.ToString();
        var house = houseList.FirstOrDefault(h => h.ID == houseId);

        if (house != null)
        {
            editingHouseId = houseId;
            lblEditTitle.Text = $"Edit House - {house.Name}";

            txtEditName.Text = house.Name;
            txtEditName.ForeColor = Color.White;
            txtEditAddress.Text = house.Address;
            txtEditAddress.ForeColor = Color.White;
            txtEditPrice.Text = house.Price.ToString();
            txtEditPrice.ForeColor = Color.White;
            txtEditBedrooms.Text = house.Bedrooms.ToString();
            txtEditBedrooms.ForeColor = Color.White;
            txtEditBathrooms.Text = house.Bathrooms.ToString();
            txtEditBathrooms.ForeColor = Color.White;
            txtEditSquareFeet.Text = house.SquareFeet.ToString();
            txtEditSquareFeet.ForeColor = Color.White;
            txtEditOwner.Text = string.IsNullOrEmpty(house.OwnerName) ? "Owner Name" : house.OwnerName;
            txtEditOwner.ForeColor = string.IsNullOrEmpty(house.OwnerName) ? Color.DarkGray : Color.White;
            txtEditPhone.Text = string.IsNullOrEmpty(house.OwnerPhone) ? "Owner Phone" : house.OwnerPhone;
            txtEditPhone.ForeColor = string.IsNullOrEmpty(house.OwnerPhone) ? Color.DarkGray : Color.White;
            txtEditDescription.Text = string.IsNullOrEmpty(house.Description) ? "Description" : house.Description;
            txtEditDescription.ForeColor = string.IsNullOrEmpty(house.Description) ? Color.DarkGray : Color.White;
            cmbEditStatus.SelectedItem = house.Status;

            pnlEditHouseDialog.Visible = true;
            pnlEditHouseDialog.BringToFront();
        }
    }
}

private void HandleDeleteHouse()
{
    if (dgvHouses.SelectedRows.Count > 0)
    {
        string houseId = dgvHouses.SelectedRows[0].Cells["ID"].Value.ToString();
        string houseName = dgvHouses.SelectedRows[0].Cells["Name"].Value.ToString();

        DialogResult result = MessageBox.Show($"Are you sure you want to delete '{houseName}'?",
                                              "Confirm Delete",
                                              MessageBoxButtons.YesNo,
                                              MessageBoxIcon.Warning);

        if (result == DialogResult.Yes)
        {
            var target = houseList.FirstOrDefault(h => h.ID == houseId);
            if (target != null)
            {
                houseList.Remove(target);

                for (int i = 0; i < houseList.Count; i++)
                {
                    houseList[i].ID = (i + 1).ToString();
                }

                isDataChanged = true;
                txtSearch.Text = " 🔍 Search...";
                txtSearch.ForeColor = Color.DarkGray;
                txtSearch.Font = new Font("Segoe UI", 11, FontStyle.Italic);
                cmbStatusFilter.SelectedIndex = 0;

                ShowHousesGrid();
                btnDeleteHouse.Visible = false;
                btnEditHouse.Visible = false;
                UpdateStatusBar();
                SaveData();
            }
        }
    }
}

private void FilterHouses(string keyword)
{
    if (string.IsNullOrWhiteSpace(keyword))
    {
        ShowHousesGrid();
        return;
    }

    dgvHouses.Rows.Clear();
    var filtered = houseList.Where(h =>
        h.Name.ToLower().Contains(keyword.ToLower()) ||
        h.Address.ToLower().Contains(keyword.ToLower()) ||
        h.OwnerName.ToLower().Contains(keyword.ToLower()) ||
        h.ID.Contains(keyword)).ToList();

    foreach (var house in filtered)
    {
        AddHouseToGrid(house);
    }

    lblTotalRecords.Text = $"Showing {filtered.Count} of {houseList.Count} houses";
}

private void FilterByStatus(string status)
{
    dgvHouses.Rows.Clear();
    var filtered = houseList.Where(h => h.Status == status).ToList();

    foreach (var house in filtered)
    {
        AddHouseToGrid(house);
    }

    lblTotalRecords.Text = $"Showing {filtered.Count} of {houseList.Count} houses";
}

private void AddHouseToGrid(House house)
{
    dgvHouses.Rows.Add(
        house.ID,
        house.Name,
        house.Address,
        house.Status,
        house.Price,
        house.Bedrooms,
        house.Bathrooms,
        house.SquareFeet,
        house.OwnerName
    );
}

private void ShowHousesGrid()
{
    SetActiveButton(btnHouses);

    lblSectionTitle.Text = "Manage Houses";
    dgvHouses.Visible = true;
    btnAddHouse.Visible = true;
    txtSearch.Visible = true;
    cmbStatusFilter.Visible = true;
    btnDeleteHouse.Visible = dgvHouses.SelectedRows.Count > 0;
    btnEditHouse.Visible = dgvHouses.SelectedRows.Count > 0;

    cardTotalHouses.Visible = false;
    cardAvailableHouses.Visible = false;
    cardRentedHouses.Visible = false;
    cardMaintenanceHouses.Visible = false;

    if (txtSearch.Text == " 🔍 Search..." || string.IsNullOrWhiteSpace(txtSearch.Text))
    {
        dgvHouses.Rows.Clear();
        foreach (var house in houseList)
        {
            AddHouseToGrid(house);
        }
        lblTotalRecords.Text = $"Total: {houseList.Count} houses";
    }
}

