private void ApplyRoundedCorners(Control control, int radius)
{
    try
    {
        control.Region = Region.FromHrgn(CreateRoundRectRgn(0, 0, control.Width, control.Height, radius, radius));
    }
    catch { }
}

private void HandleLogout()
{
    if (isDataChanged)
    {
        DialogResult result = MessageBox.Show("You have unsaved changes. Save before logging out?",
                                              "Save Changes",
                                              MessageBoxButtons.YesNoCancel,
                                              MessageBoxIcon.Question);

        if (result == DialogResult.Yes)
        {
            SaveData();
        }
        else if (result == DialogResult.Cancel)
        {
            return;
        }
    }

    pnlSidebar.Visible = false;
    pnlHeader.Visible = false;
    pnlMainContent.Visible = false;
    pnlGlassCard.Visible = true;
    txtEmail.Text = "Username";
    txtEmail.ForeColor = Color.DarkGray;
    txtPassword.Text = "Password";
    txtPassword.ForeColor = Color.DarkGray;
    txtPassword.PasswordChar = '\0';
    chkShowPassword.Checked = false;
}

protected override void OnPaint(PaintEventArgs e)
{
    base.OnPaint(e);

    e.Graphics.SmoothingMode = SmoothingMode.HighQuality;
    e.Graphics.PixelOffsetMode = PixelOffsetMode.HighQuality;

    using (LinearGradientBrush dualBrush = new LinearGradientBrush(
        this.ClientRectangle,
        Color.FromArgb(105, 30, 75),
        Color.FromArgb(14, 12, 22),
        65F))
    {
        e.Graphics.FillRectangle(dualBrush, this.ClientRectangle);
    }
}

protected override void OnFormClosing(FormClosingEventArgs e)
{
    if (isDataChanged)
    {
        DialogResult result = MessageBox.Show("You have unsaved changes. Save before exiting?",
                                              "Save Changes",
                                              MessageBoxButtons.YesNoCancel,
                                              MessageBoxIcon.Question);

        if (result == DialogResult.Yes)
        {
            SaveData();
        }
        else if (result == DialogResult.Cancel)
        {
            e.Cancel = true;
            return;
        }
    }

    autoSaveTimer.Stop();
    base.OnFormClosing(e);
}
