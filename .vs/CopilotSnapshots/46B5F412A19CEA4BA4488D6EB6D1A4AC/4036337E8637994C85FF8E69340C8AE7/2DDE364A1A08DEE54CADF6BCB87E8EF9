        // رسم تدرج الخلفية الاحترافي والعميق
        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            e.Graphics.SmoothingMode = SmoothingMode.AntiAlias;
            using (LinearGradientBrush premiumBrush = new LinearGradientBrush(
                this.ClientRectangle,
                Color.FromArgb(11, 16, 29),   // كحلي ليلي عميق
                Color.FromArgb(23, 28, 41),   // ماغنيسيوم مودرن داكن
                55F))
            {
                e.Graphics.FillRectangle(premiumBrush, this.ClientRectangle);
            }
        }
