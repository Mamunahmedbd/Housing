        // رسم الخلفية الفنية المدمجة ثلاثية الأبعاد (3D Cinematic Gradient Wallpaper)
        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            e.Graphics.SmoothingMode = SmoothingMode.AntiAlias;

            // دمج لون البنفسجي الساحر والوردي الليلي العميق بزاوية سينمائية مائلة 45 درجة
            using (LinearGradientBrush bgBrush = new LinearGradientBrush(
                this.ClientRectangle,
                Color.FromArgb(46, 16, 56),    // درجة الماغنيسيوم الأرجواني الداكن
                Color.FromArgb(15, 12, 30),    // درجة الكحلي المخملي العميق
                45F))
            {
                e.Graphics.FillRectangle(bgBrush, this.ClientRectangle);
            }

            // رسم لمسة ديكور هندسية خلفية ناعمة لتعزيز مظهر الـ Premium UI
            using (Pen decoPen = new Pen(Color.FromArgb(15, 255, 255, 255), 3))
            {
                e.Graphics.DrawEllipse(decoPen, -50, -50, 400, 400);
                e.Graphics.DrawEllipse(decoPen, 200, 350, 300, 300);
            }
        }
